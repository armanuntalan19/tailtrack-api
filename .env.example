# Copy this file to .env and fill in your values
# Never commit the actual .env to GitHub

# PostgreSQL connection string
# Format: postgresql://username:password@host:5432/database_name
#
# Render example:
#   postgresql://tailtrack_user:yourpassword@dpg-xxxx.oregon-postgres.render.com/tailtrack
#
# Supabase example (use the "URI" from Settings > Database):
#   postgresql://postgres:yourpassword@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secret — change this to a long random string before deploying
SECRET_KEY=changethisbeforegoingtoprduction123!
